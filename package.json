{
  "name": "@hw-platform/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "setup": "npx tsx scripts/setup.ts",
    "setup:skip-docker": "npx tsx scripts/setup.ts --skip-docker",
    "setup:minimal": "npx tsx scripts/setup.ts --skip-ava --skip-search",
    "setup:fresh": "docker-compose down -v && node -e \"const fs=require('fs');const p='.env';if(fs.existsSync(p)){fs.unlinkSync(p);console.log('[INFO] .env deleted');}\" && npm run setup",
    "pack:build": "npx tsx scripts/build-pack.ts",
    "dev:web": "nx serve web-client",
    "dev:web-control-plane": "nx serve web-control-plane",
    "dev:api": "nx serve api",
    "dev:control-plane": "nx serve control-plane",
    "dev:worker": "nx serve worker",
    "dev:platform": "nx run-many --target=serve --projects=api,worker,web-client",
    "dev:all": "nx run-many --target=serve --projects=api,control-plane,worker,web-client,web-control-plane",
    "ollama:start": "docker-compose up -d ollama",
    "ollama:pull": "docker exec hw_ollama ollama pull llama3:latest && docker exec hw_ollama ollama pull nomic-embed-text",
    "ollama:check": "curl -s http://localhost:11434/api/tags || echo 'Ollama not running. Start with: npm run ollama:start'",
    "lint": "nx run-many --target=lint --all",
    "format": "prettier --check .",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:reset": "docker-compose down -v && docker-compose up -d",
    "migration:generate:instance": "ts-node -P scripts/tsconfig.migration.json ./node_modules/typeorm/cli.js migration:generate -d scripts/datasource-instance.ts",
    "migration:run:instance": "ts-node -r tsconfig-paths/register -P scripts/tsconfig.migration.json ./node_modules/typeorm/cli.js migration:run -d scripts/datasource-instance.ts",
    "migrate:run:instance:job": "nx build svc-migrations && node dist/apps/svc-migrations/main.js",
    "migration:revert:instance": "ts-node -P scripts/tsconfig.migration.json ./node_modules/typeorm/cli.js migration:revert -d scripts/datasource-instance.ts",
    "migration:generate:control-plane": "ts-node -P scripts/tsconfig.migration.json ./node_modules/typeorm/cli.js migration:generate -d scripts/datasource-control-plane.ts",
    "migration:run:control-plane": "ts-node -r tsconfig-paths/register -P scripts/tsconfig.migration.json ./node_modules/typeorm/cli.js migration:run -d scripts/datasource-control-plane.ts",
    "migration:revert:control-plane": "ts-node -P scripts/tsconfig.migration.json ./node_modules/typeorm/cli.js migration:revert -d scripts/datasource-control-plane.ts",
    "password:hash": "npx tsx scripts/generate-password-hash.ts",
    "compliance:check": "npx tsx tools/design-compliance/terminology-scanner.ts",
    "compliance:check:strict": "npx tsx tools/design-compliance/terminology-scanner.ts --strict",
    "compliance:check:json": "npx tsx tools/design-compliance/terminology-scanner.ts --json",
    "authz:check": "npx tsx tools/authz-bypass-check.ts",
    "audit:check": "npx tsx tools/audit-bypass-check.ts",
    "load:envelope": "npx tsx tools/load-envelope.ts",
    "security:check": "npx tsx tools/security-bypass-check.ts",
    "service-boundary:check": "npx tsx tools/service-boundary-check.ts",
    "deps:check": "npx tsx tools/approved-deps-check.ts",
    "cicd:check": "npx tsx tools/ci-cd-wiring-check.ts",
    "selftest:framework": "npx tsx tools/scanner-self-test.ts",
    "selftest:security": "npx tsx tools/security-bypass-check-selftest.ts",
    "selftest:authz": "npx tsx tools/authz-bypass-check-selftest.ts",
    "selftest:service-boundary": "npx tsx tools/service-boundary-check-selftest.ts",
    "selftest:dead-code": "npx tsx tools/dead-code-check-selftest.ts",
    "selftest:eslint-rules": "node tools/eslint-rules/no-versioned-identifier.spec.cjs",
    "selftest:scanners": "npm run selftest:framework && npm run selftest:security && npm run selftest:authz && npm run selftest:service-boundary && npm run selftest:dead-code && npm run selftest:eslint-rules && npm run selftest:migrations && npm run selftest:silent-skip && npm run selftest:audit && npm run selftest:service-token && npm run selftest:no-hs256 && npm run selftest:no-untyped-req",
    "selftest:silent-skip": "npx tsx tools/silent-skip-check-selftest.ts",
    "selftest:audit": "npx tsx tools/audit-bypass-check-selftest.ts",
    "silent-skip:check": "npx tsx tools/silent-skip-check.ts",
    "license:check": "npx --yes license-checker --production --excludePackages \"@hw-platform/source\" --json > tmp/licenses.json && npx tsx tools/validate-licenses.ts tmp/licenses.json tools/license-allowlist.json",
    "dead-code:check": "npx tsx tools/dead-code-check.ts",
    "migrations:check": "npx tsx tools/migration-blocking-index-check.ts",
    "selftest:migrations": "npx tsx tools/migration-blocking-index-check-selftest.ts",
    "entity-schema:check": "npx tsx tools/scanners/entity-schema-ownership-check.ts",
    "selftest:entity-schema": "npx tsx tools/scanners/entity-schema-ownership-check-selftest.ts",
    "service-token:check": "npx tsx tools/scanners/service-token-default-deny-check.ts",
    "selftest:service-token": "npx tsx tools/scanners/service-token-default-deny-check-selftest.ts",
    "no-hs256:check": "npx tsx tools/scanners/no-hs256-signing-check.ts",
    "selftest:no-hs256": "npx tsx tools/scanners/no-hs256-signing-check-selftest.ts",
    "no-untyped-req:check": "npx tsx tools/scanners/no-untyped-req-check.ts",
    "selftest:no-untyped-req": "npx tsx tools/scanners/no-untyped-req-check-selftest.ts",
    "cross-domain:check": "npx tsx tools/scanners/cross-domain-import-check.ts",
    "selftest:cross-domain": "npx tsx tools/scanners/cross-domain-import-check-selftest.ts",
    "migration-filename:check": "npx tsx tools/scanners/migration-filename-check.ts",
    "selftest:migration-filename": "npx tsx tools/scanners/migration-filename-check-selftest.ts",
    "permissions-coverage:check": "npx tsx tools/scanners/permissions-annotation-coverage.ts --report=docs/permissions-rollout-coverage.md",
    "selftest:permissions-coverage": "npx tsx tools/scanners/permissions-annotation-coverage-selftest.ts",
    "abac-coverage:check": "npx tsx tools/scanners/abac-coverage-check.ts",
    "selftest:abac-coverage": "npx tsx tools/scanners/abac-coverage-check-selftest.ts",
    "schema-map:generate": "npx tsx tools/scanners/generate-schema-ownership-map.ts",
    "prelude:validate": "npx tsx scripts/prelude-validate.ts",
    "schema:manifest": "npx tsx tools/schema-manifest.ts",
    "schema:manifest:self-test": "npx tsx tools/schema-manifest.ts --self-test"
  },
  "private": true,
