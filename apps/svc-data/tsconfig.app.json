{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "module": "commonjs",
    "types": ["node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "moduleResolution": "node"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/app/flows.disabled/**/*",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "**/__tests__/**",
    "src/test-utils/**/*"
  ]
}
