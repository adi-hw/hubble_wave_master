# HubbleWave environment variables — example values only.
# Copy to `.env` and replace every value with a real secret. Never commit `.env`.
#
# Quickstart for local dev:
#   1. cp .env.example .env
#   2. npx ts-node scripts/generate-local-dev-secrets.ts >> .env
#      (appends fresh internal-secret values; review the printed block first)
#   3. Fill in external-service tokens manually (Cloudflare, HuggingFace, etc.)
#   4. docker-compose up -d
#   5. npm run migration:run:instance && npm run migration:run:control-plane
#
# Production: every value belongs in AWS Secrets Manager (or your platform's
# secrets store), not in a tracked file. See SECRETS_ROTATION.md.

# ---------------------------------------------------------------------------
# Core auth — REQUIRED, no fallbacks (services fail to start without these)
# ---------------------------------------------------------------------------

# JWT signing secret. Min 32 chars. The same value MUST be set on every
# service that issues or verifies tokens (svc-identity issues, all others
# verify). Generate via:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
IDENTITY_JWT_SECRET=

# JWT audience + issuer claims (Wave 3 migration). REQUIRED in production.
# Every service must agree on these values; mismatched values reject all
# tokens. Force a re-login when these are rotated.
JWT_AUDIENCE=hubblewave-instance
JWT_ISSUER=hubblewave-identity

# Optional: if set on a service, asserts that JWT_AUDIENCE matches this
# value at startup (catches "I set audience=foo on identity but audience=bar
# on data" misconfigurations). Recommended in production CD.
JWT_AUDIENCE_EXPECTED=

# CSV of CORS-allowed origins. REQUIRED in production — empty value
# fails closed (refuses all cross-origin requests). In dev, *.localhost
# patterns are auto-allowed.
CORS_ORIGINS=https://app.hubblewave.com

# ---------------------------------------------------------------------------
# Bootstrap admin (first-run only)
# ---------------------------------------------------------------------------

# Required when running the seed-admin-user migration on a fresh instance.
# MUST be at least 12 chars. Operator MUST rotate after first login.
DEFAULT_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Database (instance + control-plane)
# ---------------------------------------------------------------------------

# Instance DB
DB_HOST=localhost
DB_PORT=5432
DB_USER=hubblewave
DB_PASSWORD=
DB_NAME=hubblewave

# Control-plane DB
CONTROL_PLANE_DB_HOST=localhost
CONTROL_PLANE_DB_PORT=5432
CONTROL_PLANE_DB_USER=hubblewave
CONTROL_PLANE_DB_PASSWORD=
CONTROL_PLANE_DB_NAME=hubblewave_control_plane

# TLS posture. In production, certificate verification is mandatory.
# DB_SSL=true enables SSL; DB_SSL_REJECT_UNAUTHORIZED=true validates the cert
# chain. DB_SSL_CA points at the RDS / Cloud SQL CA bundle.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA=

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------

# Connection URL. Production uses rediss:// (TLS) with embedded auth token;
# the customer-instance Terraform module emits this format.
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_AUTH_TOKEN=
REDIS_TLS=false

# ---------------------------------------------------------------------------
# Pack signing & install (svc-instance-api + scripts/build-pack.ts)
# ---------------------------------------------------------------------------

# Ed25519 public key used by svc-instance-api to verify pack manifest
# signatures at install time. PEM-encoded, multi-line. Generate via:
#   npx ts-node scripts/generate-pack-signing-keypair.ts
PACK_SIGNING_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
<base64 body>
-----END PUBLIC KEY-----"

# Ed25519 private key used by the build-pack tool to sign pack manifests.
# Lives only on the build machine / CI signer — NEVER on instance runtimes.
PACK_SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
<base64 body>
-----END PRIVATE KEY-----"

# Shared secret presented as the X-Pack-Install-Token header by the
# control-plane caller of POST /api/packs/install. Rotate on leak.
PACK_INSTALL_TOKEN=

# Comma-separated allowlist of artifact hostnames. Wildcards allowed (e.g.
# `*.hubblewave.com`). If unset, defaults to `*.hubblewave.com,s3.amazonaws.com,
# *.s3.us-east-2.amazonaws.com`.
PACK_ARTIFACT_HOST_ALLOWLIST=

# Set to `true` to bypass pack manifest signature verification. ONLY honoured
# when NODE_ENV !== 'production'. Logs a loud warning whenever it takes effect.
PACK_SIGNING_DEV_SKIP=false

# ---------------------------------------------------------------------------
# Backup signing (svc-insights backup.service)
# ---------------------------------------------------------------------------

# HMAC-SHA256 key used to sign backup manifests + Typesense schema dumps;
# verified before restore. Rotation forces re-signing of existing backups
# (or they become unrestorable). Generate via:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
BACKUP_SIGNING_KEY=

# ---------------------------------------------------------------------------
# Outbound URL safety (libs/integrations validateOutboundUrl)
# ---------------------------------------------------------------------------

# CSV of hostnames the platform may call. Wildcards allowed.
# Example: hooks.example.com,*.partner.com,api.stripe.com
OUTBOUND_HOST_ALLOWLIST=

# ---------------------------------------------------------------------------
# Authorization (libs/authorization)
# ---------------------------------------------------------------------------

# Dev-only escape hatch. When NODE_ENV !== 'production' and this is set
# to 'true', ABAC matches() returns true on missing policy condition
# (permissive — useful while authoring policies locally). In production
# the flag is ignored and ABAC always fails closed on missing policy
# per canon §10.
ABAC_DEFAULT_ALLOW=false

# ---------------------------------------------------------------------------
# AI providers (libs/ai)
# ---------------------------------------------------------------------------

# Anthropic / OpenAI primary providers. If unset, the LLM provider service
# fails closed in production (no mock fallback).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# vLLM provider. URL + API key. Constructor throws in production if URL
# matches a hosted-LLM marker (api.anthropic.com / api.openai.com / etc.)
# without a key.
VLLM_API_URL=
VLLM_API_KEY=

# ---------------------------------------------------------------------------
# Sandbox / runtime tuning (svc-automation, svc-data)
# ---------------------------------------------------------------------------

# Maximum AST depth for expr-eval scripts in automation conditions. Default 64.
SCRIPT_MAX_AST_DEPTH=64

# Idempotency window for notification queue dedup (in hours). Default 24.
NOTIFY_IDEMPOTENCY_WINDOW_HOURS=24

# Email channel (svc-notify SmtpEmailProvider). When SMTP_HOST and
# SMTP_PORT are set the email channel is registered and outbound mail
# actually ships. When unset the email channel fails closed (delivery
# rows are marked failed with a clear "no provider configured" reason)
# rather than silently dropping. SMTP_USER/SMTP_PASS are optional for
# providers that allow anonymous relay; SMTP_FROM controls the From:
# header (defaults to NOTIFY_FROM, then SMTP_USER, then a placeholder).
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
NOTIFY_FROM=

# S3 presigned URL TTL in seconds. Default 3600 (1 hour). Capped at
# 604800 (7 days). The platform clamps to [1, 604800].
S3_SIGNED_URL_TTL_SECONDS=3600

# ---------------------------------------------------------------------------
# Test fixtures
# ---------------------------------------------------------------------------

# When true (and only when NODE_ENV !== 'production'), the
# 1800000000001-create-inline-editing-test migration runs to create a
# test collection used by the inline-editing UI test page. Production
# instances should leave this unset.
HW_INCLUDE_TEST_FIXTURES=false

# ---------------------------------------------------------------------------
# Local development services (docker-compose.yml)
#
# These values feed the compose file via ${VAR:?must be set} substitution.
# Every value must be supplied; compose intentionally has no defaults so a
# misconfigured developer environment fails fast rather than silently
# binding to weak credentials.
# ---------------------------------------------------------------------------

# PostgreSQL (pgvector)
POSTGRES_USER=hubblewave
POSTGRES_PASSWORD=
POSTGRES_DB=hubblewave

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Typesense full-text search API key.
# Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TYPESENSE_API_KEY=

# ---------------------------------------------------------------------------
# Control-plane internal
# ---------------------------------------------------------------------------

# Shared secret used by instance-plane services to authenticate calls back
# to the control plane (e.g., license validation). Compared via
# crypto.timingSafeEqual.
CONTROL_PLANE_INSTANCE_TOKEN=
