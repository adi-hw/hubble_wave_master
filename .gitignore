# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
libs/**/*.js
libs/**/*.js.map
migrations/**/*.js
migrations/**/*.js.map
scripts/*.js
scripts/*.js.map

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

vite.config.*.timestamp*
# Environment files (NEVER commit secrets!)
.env*
!.env.example
!.env.production.example
**/*.env.backup
apps/**/.env
libs/**/.env
**/secrets.json
**/credentials.json

# Reference PDFs (ServiceNow docs) — sit alongside the repo for offline
# reading but must never be committed (100MB+ each).
servicenow-*.pdf
**/servicenow-*.pdf

# canon §29.9 — local ES256 JWT signing keys. Generated automatically by
# LocalEs256KeySigningService on first dev/test startup. Mode 0600 on disk;
# the provider refuses to start if any file here is group/other-readable.
# MUST NEVER be committed.
.dev/keys/
.dev/keys/*
.dev/baseline/

# Local Claude Code settings (machine-local, never committed)
.claude/settings.local.json
.claude/*.local.md
.claude/worktrees/

# Local git worktrees rooted under the repo. The worktree's nested
# `apps/` and `libs/` directories carry duplicate Nx project entries
# (each worktree is a full repo checkout), and Nx's project graph +
# Jest's project resolver scan the repo root recursively — every
# nested worktree poisons workspace-level test commands with
# duplicate-project errors. Move worktrees outside the repo if
# possible; this rule is the seatbelt for ones that land inside.
phase4-wt/
*-wt/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
**/*.tfvars
!**/*.tfvars.example
tools/terraform/terraform.exe
infrastructure/terraform/environments/*/.terraform/
